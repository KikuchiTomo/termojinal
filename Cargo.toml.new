[workspace]
members = [
    "crates/jterm-pty",
    "crates/jterm-vt",
    "crates/jterm-session",
    "crates/jterm-render",
    "crates/jterm-layout",
    "crates/jterm-ipc",
    "crates/jterm-claude",
]
resolver = "2"

[workspace.package]
edition = "2021"
license = "MIT"
repository = "https://github.com/tomokikuchi/jterm"

[package]
name = "jterm"
version = "0.1.0"
edition.workspace = true

[[bin]]
name = "jterm-dev"
path = "src/main.rs"

[dependencies]
jterm-pty = { path = "crates/jterm-pty" }
jterm-vt = { path = "crates/jterm-vt" }
jterm-session = { path = "crates/jterm-session" }
jterm-render = { path = "crates/jterm-render" }
jterm-layout = { path = "crates/jterm-layout" }
jterm-ipc = { path = "crates/jterm-ipc" }
log = "0.4"
env_logger = "0.11"
nix = { version = "0.29", features = ["signal", "term"] }
libc = "0.2"
vte = "0.13"
winit = "0.30"
wgpu = "24"
pollster = "0.4"
arboard = "3"
base64 = "0.22"
serde = { version = "1", features = ["derive"] }
toml = "0.8"
dirs = "6"
gethostname = "0.5"
image = { version = "0.25", default-features = false, features = ["png"] }
raw-window-handle = "0.6"
unicode-width = "0.2"

[target.'cfg(target_os = "macos")'.dependencies]
objc2 = "0.5"
